# Copy this file to .env.local for local development.
# In Vercel: Settings → Environment Variables → add each key below.

VITE_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-project-id
VITE_APPWRITE_DATABASE_ID=your-database-id
VITE_APPWRITE_BUCKET_ID=your-storage-bucket-id

VITE_APPWRITE_COLLECTION_LIBRARIES=libraries
VITE_APPWRITE_COLLECTION_SUBMISSIONS=submissions
VITE_APPWRITE_COLLECTION_DOCUMENTS=documents
VITE_APPWRITE_COLLECTION_BLOCKS=blocks
VITE_APPWRITE_COLLECTION_CATEGORIES=categories
